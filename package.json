{
  "name": "openpoke-think-assistant",
  "description": "OpenPoke-style orchestrator assistant built on Cloudflare Think and Agents",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "start": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest --run --config src/tests/vitest.config.ts",
    "types": "wrangler types env.d.ts --include-runtime false"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "*",
    "@cloudflare/codemode": "*",
    "@cloudflare/kumo": "^2.1.0",
    "@cloudflare/shell": "*",
    "@cloudflare/think": "*",
    "@phosphor-icons/react": "^2.1.10",
    "agents": "*",
    "ai": "^6.0.180",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.4",
    "@cloudflare/vitest-pool-workers": "^0.16.5",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  }
}
